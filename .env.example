HADITH_MCP_COMMAND=node
HADITH_MCP_CWD=/Users/abdulrahman/Projects/hadith-mcp
HADITH_MCP_CLI_PATH=/Users/abdulrahman/Projects/hadith-mcp/packages/hadith-mcp/dist/cli.js
HADITH_MCP_DB_PATH=/Users/abdulrahman/Projects/hadith-mcp/data/generated/hadith-meeatif.sqlite
TAFSIR_MCP_COMMAND=uvx
TAFSIR_MCP_ARGS=tafsir-mcp
# Optional: TAFSIR_DB_PATH=/Users/abdulrahman/.cache/tafsir-mcp/quran.db
OPENROUTER_API_KEY=
# Optional: management key enables proactive low-credit checks.
OPENROUTER_MANAGEMENT_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Sanad AI
LLM_TIMEOUT_MS=25000
# Mobile credit alerts via the ntfy iOS/Android app.
NTFY_TOPIC=
NTFY_BASE_URL=https://ntfy.sh
# Optional for a reserved/private ntfy topic.
NTFY_ACCESS_TOKEN=
OPENROUTER_LOW_CREDIT_USD=1
OPENROUTER_CREDIT_CHECK_INTERVAL_MS=900000
CREDIT_ALERT_TIMEOUT_MS=4000
# Optional: ANSWER_MODEL=google/gemini-3.1-flash-lite
# Optional: ANSWER_FALLBACK_MODELS=mistralai/mistral-small-2603
MCP_TOOL_ROUTER_ENABLED=true
# Optional: MCP_TOOL_ROUTER_MODEL=google/gemini-3.1-flash-lite
# Optional: MCP_TOOL_ROUTER_FALLBACK_MODELS=mistralai/mistral-small-2603
# Optional: MCP_TOOL_ROUTER_TIMEOUT_MS=12000
HADITH_QUERY_PLANNER_ENABLED=true
# Optional: HADITH_QUERY_PLANNER_MODEL=google/gemini-3.1-flash-lite
# Optional: HADITH_QUERY_PLANNER_FALLBACK_MODELS=mistralai/mistral-small-2603
# Optional: HADITH_QUERY_PLANNER_TIMEOUT_MS=12000
# Convex dashboard backend (created by `npx convex dev`).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
DASHBOARD_INGEST_SECRET=replace-with-a-long-random-secret
